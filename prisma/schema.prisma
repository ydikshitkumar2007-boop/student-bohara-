datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Inquiry {
  id           String   @id @default(uuid())
  fullName     String
  email        String
  organization String
  division     String
  message      String
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
